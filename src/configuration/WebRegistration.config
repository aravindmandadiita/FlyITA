<?xml version="1.0" encoding="utf-8"?>
<settings>
  <!-- 
		specify ProgramID for the current website if known, otherwise set to zero to allow lookup
		if not setting ProgramID, specify ITAProgNbr (ex: 2D4G7L) if known, otherwise leave empty
		if neither of these is filled in, the system will try to do a lookup based upon URL
	-->
  <ProgramID value="" />
  <ITAProgNbr value="" />

  <!-- 2T111S, 2T222Q, 2T000Q, 2KKGZA, 2NXR73, 2UJHGF, 2AH0AI, 29V4NU,Keynote :02I07Z1 -->

  <!--This setting is a manual switch to turn off reading each page settings from DB set by WebRegAdmin-->
  <ReadWebRegSettings value="true" />

  <!-- default display settings for SSL site seal - may be overridden on individual pages with
		 the display_ssl_seal page attribute 
		 NOTE: SSL will be enforced on all non-localhost environments regardless of whether the site seal is displayed -->
  <DisplaySSLSeal value="false" />

  <!-- control javascript timeout controls
	    - warning will display in TimeoutWarningSeconds seconds - set to 0 (zero) to disable
			- automatic logout will occur TimeoutSeconds seconds later -->
  <TimeoutWarningSeconds value="1080" />
  <TimeoutSeconds value="90" />

  <!-- javascript will be used to force Forward history in the browser so the user cannot use their 
		 Back button to return to previous pages.  Set this value to true to disable this behavior.
		 This setting may be overridden on an individual page with the disable_forward_script setting for
		 that individual page. -->
  <DisableForwardScript value="false" />

  <!-- javascript will set focus to top of window (pixel 0,0) on page loads -->
  <ScrollToWindowTop value ="true" />

  <!-- date format for events page -->
  <DateFormat value="MM/DD/YYYY" />
  <!-- time format for events page (12 or 24) -->
  <TimeFormat value="12" />

  <!-- navigation target if session expires or direct navigation to a secured page is attempted -->
  <MissingAuthenticationTarget value="login.aspx" />

  <!-- navigation target if direct navigation to a controlled page is attempted and there is no CurrentPage -->
  <InvalidNavigationTarget value="login.aspx" />

  <!-- text to be inserted into terms textarea on termsandconditions.aspx -->
  <TermsAndConditionsPath value="configuration/TermsAndConditions.txt" />

  <!-- type of text for terms and conditions - options are 'text' and 'html'  -->
  <TermsAndConditionsType value="text" />
  <FromEmail value="autodelete@itagroup.com"/>
  
  <TravelerProfilerTemplate  value="configuration/TravelerProfiler.html"/>
  <VacationTravelRequesTemplate  value="configuration/VacationTravelRequest.html"/>
  <!--  Available fields -->
  <!--  PARTICIPANT_NAME, PARTICIPANT_EMAIL, PARTICIPANT_USERNAME, PARTICIPANT_PASSWORD -->
  <!--  PROGRAM_NAME, PROGRAM_HQNAME, PROGRAM_EMAIL, PROGRAM_URL, PROGRAM_800NBR        -->

  <!-- Third Party Email  -->
  <ThirdPartyEmailTemplate value="configuration/ThirdPartyEmailTemplate.txt" />
  <ThirdPartyEmailTo value="[PARTICIPANT_EMAIL]" />
  <ThirdPartyEmailCC value="[PROGRAM_EMAIL]" />
  <ThirdPartyEmailFrom value="[PROGRAM_EMAIL]" />
  <ThirdPartyEmailSubject value="[PARTICIPANT_NAME] - Participant Registration" />

  <!-- Custom Registration Confirmation -->
  <RegistrationConfirmationEmailTemplate value="configuration/RegistrationConfirmationEmail.html" />
  <RegistrationConfirmationEmailSubject value="[PROGRAM_NAME] - Registration Acknowledgement" />

  <!-- Custom Logon Credentials -->
  <LogonCredentialsEmailTemplate value="configuration/LogonCredentialsEmail.html" />
  <LogonCredentialsEmailSubject value="[PROGRAM_NAME] Logon Credentials" />

  <!-- Forgot Password Logon Credentials -->
  <SeamlessLogonCredentialsEmail value="configuration/SeamlessLogonCredentialsEmail.html" />
  <SeamlessLogonCredentialsSubject value="[PROGRAM_NAME] Logon Credentials" />

  <!-- Postcard Template-->
  <!--Commented as it is not used as part of base temmplate-->
  <!--<PostcardEmail value="configuration/PostcardMessage.html" />-->

  <!-- used to customize profileinformation.aspx -->
  <PassportNameValidation value="false" />

  <!-- number of guests allowed of each type -->
  <guests>
    <main value="1" />
    <additional value="1" />
    <nonparticipating value="0" />
  </guests>

  <!--Fees section default settings
      This section is used to create custom labels.
      The value is | delimited with key/value pair.
      It is being passed to the service as a string.
      If you don't pass a value it will be empty on the IFrame screen as all the settings for text come from here.
      The Secure page is laid out just like fees.aspx HTML markup.
  -->
  <secureIFrameCaptureSettings value="Text_ProgramHeader|Program Fees|Label_FirstName|Cardholder First Name|Label_LastName|Cardholder Last Name|Label_CardType|Card Type|Label_CreditCardNumber|Credit Card Number|Label_ExpirationDate|Credit Card Expiration Date|Label_Required|*|Text_Header|Please provide credit card information to be used for the Program Fees above.|Text_ExtensionHeader|Extension Fees|Text_ExtensionQuestion|Should we bill the same credit card as above for your extension fees?|Text_ExtensionInstructions|If no, please enter a different credit card below. If yes, please skip to the Save and Continue button to proceed.|Setting_bCollectBoth|False|ProcessText_Loading|Loading...|ProcessText_Processing|Processing...|ProcessText_Complete|Card saved...|Error_FirstName|Cardholder First Name|Error_LastName|Cardholder Last Name|Error_PrimaryAccountNumber|Credit Card Number|Error_Expiration|Credit Card Expiration Date|Error_AlreadyCaptured|Your card information has already been saved.|Error_RequestExpired|Cannot collect card at this time."></secureIFrameCaptureSettings>
  <!--Use this for vanity URL to set up your i-frame on Fees.aspx page and call back page.
    Look in fees.aspx.vb method SetupSecureFrame
-->
  <vanityURL value=""></vanityURL>
  <SourceSystem value="WebReg"></SourceSystem>

  <AttendeeTypeList>
    <add key="atUndefined" value=""></add>
  </AttendeeTypeList>



  <!-- this section is to configure the weather widget -->
  <Weather>
    <apikey value="77d062c377552af49471a60895394694" />
    <prodapikey value="309e681f20c8c6bd4023182fbf15b7b5" />
    <latitude value="41.594211" />
    <longitude value="-93.766841" />
    <city value="Current Weather" />
    <!-- time is an optional parameter. Leave it off if you don't want only one day to be pulled by forecast.io -->
    <time value="" />
  </Weather>

  <!-- 
      This section was added so that the role can be read based on URL 
      and not on a value hard coded in the web.config.
      Usage:
        role - read in the Utilities.getRole function.
        isclientfacing - read in the Utilities.IsClientFacingEnv function.
      NOTE: Until the services are rewritten we still have to keep the 
            following items in the appSettings above:
            Role, LogFilePath, and EncryptionKeyPath
    -->
  <url>
    <!--<localhost  role="CDT"        isclientfacing="false" />-->
    <localhost  role="CDT"        isclientfacing="false" />
    <uat        role="UAT"        isclientfacing="false" />
    <mp         role="Develop"    isclientfacing="false" />
    <idd        role="Develop"    isclientfacing="false" />
    <idi        role="IDI"        isclientfacing="false" />
    <eisdev     role="EISDEV"     isclientfacing="false" />
    <idt        role="IDT"        isclientfacing="false" />
    <qa         role="QA"         isclientfacing="false" />
    <eislt      role="LT"         isclientfacing="false" />
    <cdi        role="CDI"        isclientfacing="false" />
    <dev        role="CDT"        isclientfacing="false" />
    <cdt        role="CDT"        isclientfacing="false" />
    <test       role="CA"         isclientfacing="true" />
    <www        role="PR"         isclientfacing="true" />
    <dev8        role="CDT"        isclientfacing="false" />
  </url>


  all page and attribute names must be lower case
  -->
  <pages>



    <profileinformation.aspx
				 requires_authentication="false"
					enforce_nav="false"
					display_nav="true"
					display_reg_nav="true"
					reg_nav_level="profile"
          display_regfooter="false"
          display_ssl_seal="true"
          registrationstyle="Content/registrationform.css"
          target_missing_guest_info="GuestInformation.aspx"
          target_no_guests_allowed_registered="CommonTask.aspx"
          target_no_guests_allowed_unregistered="CustomFields.aspx"
          target_one_guest_allowed_with_info="GuestProfileInformation.aspx"
          target_guests_allowed="GuestInformation.aspx"
          target_exit="Logout.aspx"
          target_closed="closed.aspx"
          option_readwebregsettings="true" />
    <guestinformation.aspx
				 requires_authentication="false"
					enforce_nav="true"
          display_nav="true"
          display_reg_nav="true"
          registrationstyle="Content/registrationform.css"
          reg_nav_level="profile"
          display_regfooter="false"
          target_exit="Logout.aspx"
          target_guest="GuestProfileInformation.aspx"
          target_registered="CommonTask.aspx"
          target_unregistered="CustomFields.aspx"
          option_readwebregsettings="true" />
    <guestprofileinformation.aspx
				 requires_authentication="false"
					enforce_nav="true"
					display_nav="true"
          display_reg_nav="true"
          reg_nav_level="profile"
          display_regfooter="false"
          display_ssl_seal="true"
          registrationstyle="Content/registrationform.css"
          target_exit="Logout.aspx"
          target_inactive_guest="GuestInformation.aspx"
          target_multiple_guests="GuestInformation.aspx"
          target_single_guest_registered="CommonTask.aspx"
          target_single_guest_unregistered="CustomFields.aspx"
          option_readwebregsettings="true" />


    <help.aspx
					requires_authentication="false"
					enforce_nav="false"
					display_nav="false"
          display_logo="true"
					display_reg_nav="false"
					display_regfooter="false"
					timeout_warning_seconds="0"
					disable_forward_script="true" />
    <error.aspx
					requires_authentication="false"
					enforce_nav="false"
					display_nav="false"
					display_reg_nav="false"
					display_regfooter="false" />
    <seamlesslogin.aspx
					requires_authentication="false"
					enforce_nav="false"
					display_nav="false"
					display_reg_nav="false"
					display_regfooter="false"
					target_failed="Login.aspx"
					target_terms_selected="ProfileInformation.aspx"
					target_terms_not_selected="TermsAndConditions.aspx" />
    <home.aspx
  disable_forward_script="true"
      requires_authentication="false"/>
    <travelinfo.aspx
		   disable_forward_script="true"
       requires_authentication="false"/>
    <international.aspx
		   disable_forward_script="true"
    requires_authentication="false"/>
    <vacation.aspx
     disable_forward_script="true"
     requires_authentication="false"/>
    <aboutita.aspx
		   disable_forward_script="true"
       requires_authentication="false"/>
    <reservations.aspx
		   disable_forward_script="true"
       requires_authentication="false"/>
    <resources.aspx
			 disable_forward_script="true"
       requires_authentication="false"/>
    <programs.aspx
		   disable_forward_script="true"
       requires_authentication="false"/>
    <privacy.aspx
		   disable_forward_script="true"
       requires_authentication="false"/>
    <helpsite.aspx
		   disable_forward_script="true"
       requires_authentication="false"/>

    <participantimagereport
      	  requires_authentication="false"
					enforce_nav="false"
					display_nav="true"
					display_reg_nav="true"
					reg_nav_level="fees"
					display_regfooter="false"
					display_ssl_seal="true"
			    registrationstyle="Content/registrationform.css" />
  </pages>
</settings>
