@page "/traveler-profile"
@model FlyITA.Web.Pages.TravelerProfileModel
@{
    ViewData["Title"] = "Traveler Profile Information";
}

<div class="container py-4">
    <h1>Traveler Profile Information</h1>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post" asp-route-personId="@(Model.Person != null && Model.Person.ContainsKey("PersonID") ? Model.Person["PersonID"] : 0)">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <fieldset class="mb-4">
            <legend>Personal Information</legend>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                    <input asp-for="FirstName" class="form-control" required />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="LastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                    <input asp-for="LastName" class="form-control" required />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" type="email" required />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Phone" class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control" type="tel" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Company" class="form-label">Company</label>
                    <input asp-for="Company" class="form-control" />
                </div>
            </div>
        </fieldset>

        <fieldset class="mb-4">
            <legend>Frequent Flyer Programs</legend>
            <div id="frequent-flyers">
                @for (var i = 0; i < Model.FrequentFlyers.Count; i++)
                {
                    <div class="row g-3 mb-2 frequent-flyer-row">
                        <div class="col-md-5">
                            <label class="form-label">Airline</label>
                            <input asp-for="FrequentFlyers[i].Airline" class="form-control" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Member Number</label>
                            <input asp-for="FrequentFlyers[i].MemberNumber" class="form-control" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.frequent-flyer-row').remove()">Remove</button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mt-2" id="add-frequent-flyer">Add Frequent Flyer Program</button>
        </fieldset>

        <fieldset class="mb-4">
            <legend>Hotel Memberships</legend>
            <div id="hotel-memberships">
                @for (var i = 0; i < Model.HotelMemberships.Count; i++)
                {
                    <div class="row g-3 mb-2 hotel-membership-row">
                        <div class="col-md-5">
                            <label class="form-label">Hotel Chain</label>
                            <input asp-for="HotelMemberships[i].HotelChain" class="form-control" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Member Number</label>
                            <input asp-for="HotelMemberships[i].MemberNumber" class="form-control" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.hotel-membership-row').remove()">Remove</button>
                        </div>
                    </div>
                }
            </div>
            <button type="button" class="btn btn-outline-secondary btn-sm mt-2" id="add-hotel-membership">Add Hotel Membership</button>
        </fieldset>

        <fieldset class="mb-4">
            <legend>Rental Car Preferences</legend>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="RentalCarCompany" class="form-label">Preferred Rental Car Company</label>
                    <input asp-for="RentalCarCompany" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label asp-for="RentalCarMemberNumber" class="form-label">Member Number</label>
                    <input asp-for="RentalCarMemberNumber" class="form-control" />
                </div>
            </div>
        </fieldset>

        <input type="hidden" asp-for="CaptchaToken" id="captchaToken" />

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save Profile</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (function () {
            let ffIndex = @Model.FrequentFlyers.Count;
            document.getElementById('add-frequent-flyer').addEventListener('click', function () {
                const container = document.getElementById('frequent-flyers');
                const row = document.createElement('div');
                row.className = 'row g-3 mb-2 frequent-flyer-row';
                row.innerHTML = `
                    <div class="col-md-5">
                        <label class="form-label">Airline</label>
                        <input name="FrequentFlyers[${ffIndex}].Airline" class="form-control" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Member Number</label>
                        <input name="FrequentFlyers[${ffIndex}].MemberNumber" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.frequent-flyer-row').remove()">Remove</button>
                    </div>`;
                container.appendChild(row);
                ffIndex++;
            });

            let hmIndex = @Model.HotelMemberships.Count;
            document.getElementById('add-hotel-membership').addEventListener('click', function () {
                const container = document.getElementById('hotel-memberships');
                const row = document.createElement('div');
                row.className = 'row g-3 mb-2 hotel-membership-row';
                row.innerHTML = `
                    <div class="col-md-5">
                        <label class="form-label">Hotel Chain</label>
                        <input name="HotelMemberships[${hmIndex}].HotelChain" class="form-control" />
                    </div>
                    <div class="col-md-5">
                        <label class="form-label">Member Number</label>
                        <input name="HotelMemberships[${hmIndex}].MemberNumber" class="form-control" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.closest('.hotel-membership-row').remove()">Remove</button>
                    </div>`;
                container.appendChild(row);
                hmIndex++;
            });
        })();
    </script>
}
