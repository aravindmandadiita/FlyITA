@page "/vacation-request"
@model FlyITA.Web.Pages.VacationRequestModel
@{
    ViewData["Title"] = "Vacation Travel Request";
}

<div class="container py-4">
    <h1>Vacation Travel Request</h1>
    <p>Complete the form below to submit your leisure travel request. A travel advisor will contact you to finalize your booking.</p>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success" role="alert">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <fieldset class="mb-4">
            <legend>Traveler Information</legend>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="TravelerName" class="form-label">Full Name <span class="text-danger">*</span></label>
                    <input asp-for="TravelerName" class="form-control" required />
                    <span asp-validation-for="TravelerName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TravelerEmail" class="form-label">Email <span class="text-danger">*</span></label>
                    <input asp-for="TravelerEmail" class="form-control" type="email" required />
                    <span asp-validation-for="TravelerEmail" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="TravelerPhone" class="form-label">Phone</label>
                    <input asp-for="TravelerPhone" class="form-control" type="tel" />
                </div>
            </div>
            <p class="text-muted mt-2">Already have a <a href="/traveler-profile">Traveler Profile</a>? Your saved preferences will be used.</p>
        </fieldset>

        <fieldset class="mb-4">
            <legend>Trip Details</legend>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Destination" class="form-label">Destination <span class="text-danger">*</span></label>
                    <input asp-for="Destination" class="form-control" required />
                    <span asp-validation-for="Destination" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="DepartureDate" class="form-label">Departure Date <span class="text-danger">*</span></label>
                    <input asp-for="DepartureDate" class="form-control" type="date" required />
                    <span asp-validation-for="DepartureDate" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="ReturnDate" class="form-label">Return Date <span class="text-danger">*</span></label>
                    <input asp-for="ReturnDate" class="form-control" type="date" required />
                    <span asp-validation-for="ReturnDate" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="NumberOfTravelers" class="form-label">Number of Travelers</label>
                    <input asp-for="NumberOfTravelers" class="form-control" type="number" min="1" max="20" />
                </div>
            </div>
        </fieldset>

        <fieldset class="mb-4">
            <legend>Preferences</legend>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FlightPreferences" class="form-label">Flight Preferences</label>
                    <textarea asp-for="FlightPreferences" class="form-control" rows="3" placeholder="Preferred airlines, seat class, times..."></textarea>
                </div>
                <div class="col-md-6">
                    <label asp-for="HotelPreferences" class="form-label">Hotel Preferences</label>
                    <textarea asp-for="HotelPreferences" class="form-control" rows="3" placeholder="Preferred chains, room type, amenities..."></textarea>
                </div>
                <div class="col-md-4">
                    <label asp-for="CarRentalNeeded" class="form-label">Car Rental Needed?</label>
                    <select asp-for="CarRentalNeeded" class="form-select">
                        <option value="No">No</option>
                        <option value="Yes">Yes</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="AdditionalNotes" class="form-label">Additional Notes</label>
                    <textarea asp-for="AdditionalNotes" class="form-control" rows="3"></textarea>
                </div>
            </div>
        </fieldset>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary">Submit Travel Request</button>
        </div>
    </form>
</div>
